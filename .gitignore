# ==============================================================================
# .gitignore - Regras de exclusão para o projeto agy-pipeline
# ==============================================================================

# --- Credenciais e Configurações Sensíveis ---
# Bloqueia arquivos que contenham tokens (como GITHUB_TOKEN) ou senhas locais
.env
.env.*
!.env.exemplo
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- Arquivos Temporários e Pacotes ---
# Evita subir os pacotes baixados nas atualizações locais
*.tar.gz
*.zip
*.tgz
/tmp/
/temp/

# --- Logs de Execução ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Configurações de IDEs e Editores ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# --- Arquivos do Sistema Operacional ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
